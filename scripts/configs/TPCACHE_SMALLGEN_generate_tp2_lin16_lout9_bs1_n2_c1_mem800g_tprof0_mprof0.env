# TPCACHE_SMALLGEN: the smoke test that proves the dequant cache is
# independent of CPU core count. Uses c=1 / OMP_NUM_THREADS=1 per rank;
# reads the existing TP2 BF16 dequant cache and runs a tiny synthetic
# generate (Lin=16, Lout=9). This is not a speed run — TPOT will be
# dominated by single-threaded BF16 matmul. The purpose is to confirm
# the same TP2 cache loads cleanly under any thread count.
#
# Memory stays high (800 GB) because the BF16 cached model is ~676 GB /
# rank regardless of cores — only cores can be small.

EXPERIMENT_ID="TPCACHE_SMALLGEN"
RUN_LABEL="TPCACHE_SMALLGEN"
RUN_MODE="generate"
REAL_RUN=1

NATIVE_NO_LOAD_WEIGHTS=0
NATIVE_NO_GENERATE=0

SHARDING_MODE="tp2"
TP_SIZE=2
DP_SIZE=1
EP_SIZE=1
PP_SIZE=1

WEIGHTS_PRECISION="fp8"
KV_CACHE_DTYPE="fp8"
DEQUANT_FP8_WEIGHTS="all"
DEQUANT_CACHE_MODE="read"
DEQUANT_CACHE_PATH="/scratch/ramanvr_root/ramanvr/akashpt/models/deepseek-v3.2-tp2-bf16-dequant-all"

SHARDED_CKPT_PATH="/scratch/ramanvr_root/ramanvr/akashpt/DeepSeekRun_runtime/artifacts/deepseek-v3.2-mp2-rerun"

SBATCH_PARTITION="ramanvr"
SBATCH_ACCOUNT="ramanvr"

SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=1
SBATCH_MEM="800G"
SBATCH_TIME="01:00:00"

OMP_NUM_THREADS=1

LIN_TOKENS=16
LOUT_TOKENS=9
BATCH_SIZE=1
