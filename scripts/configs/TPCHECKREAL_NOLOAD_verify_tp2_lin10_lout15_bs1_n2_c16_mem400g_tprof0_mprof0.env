# TPCHECKREAL_NOLOAD: TP2 construct-only smoke (skip weight load + generation).
# Parser flow: source _baseline.env, then this file.
#
# Use this to confirm distributed init + Transformer(ModelArgs(**native_json))
# + per-rank parameter shape allocation, without paying the time/memory cost
# of loading the 338 GB shards. Exits 0 right after construction.

EXPERIMENT_ID="TPCHECKREAL_NOLOAD"
RUN_LABEL="TPCHECKREAL_NOLOAD"
RUN_MODE="verify"
REAL_RUN=1

NATIVE_NO_LOAD_WEIGHTS=1
NATIVE_NO_GENERATE=0

SHARDING_MODE="tp2"
TP_SIZE=2
DP_SIZE=1
EP_SIZE=1
PP_SIZE=1

WEIGHTS_PRECISION="fp8"
KV_CACHE_DTYPE="fp8"
DEQUANT_FP8_WEIGHTS="none"

SHARDED_CKPT_PATH="/scratch/ramanvr_root/ramanvr/akashpt/DeepSeekRun_runtime/artifacts/deepseek-v3.2-mp2-rerun"

# Partition/account chosen to match where the known-good TPCHECKREAL run executed.
SBATCH_PARTITION="project_l"
SBATCH_ACCOUNT="kdur"

SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=16
SBATCH_MEM="400G"
SBATCH_TIME="02:00:00"

OMP_NUM_THREADS=16
