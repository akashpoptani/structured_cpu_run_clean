# TPCHECKREAL_DEQUANTALL: TP2 real run with FP8 -> BF16 pre-dequant ("fast path").
# Parser flow: source _baseline.env, then this file.
#
# Same shape as the known-good TPCHECKREAL (token-exact PASS on case_0001)
# but with DEQUANT_FP8_WEIGHTS="all". Every FP8 Linear weight is converted
# to BF16 in place right after weight load, so subsequent F.linear calls
# take the BF16 fast path instead of the per-call FP32 fallback in
# src/overrides/kernel.py:fp8_gemm.
#
# Memory: FP8 weights (~338 GB per rank) are briefly held alongside the
# BF16 result (~676 GB per rank steady state). 800 GB / rank on ramanvr
# leaves margin above the legacy 750 GB convention.
#
# This run is NOT yet token-exact verified for the clean lane. Status will
# move to "verified" only after a successful PASS recorded here.
#
# Resource note: 16 cores + 800 GB per node on ramanvr/ramanvr — the slot
# shape available immediately on this cluster. The previous 32c/750G ask
# queued behind another job on project_l/kdur.

EXPERIMENT_ID="TPCHECKREAL_DEQUANTALL"
RUN_LABEL="TPCHECKREAL_DEQUANTALL"
RUN_MODE="verify"
REAL_RUN=1

NATIVE_NO_LOAD_WEIGHTS=0
NATIVE_NO_GENERATE=0

SHARDING_MODE="tp2"
TP_SIZE=2
DP_SIZE=1
EP_SIZE=1
PP_SIZE=1

WEIGHTS_PRECISION="fp8"
KV_CACHE_DTYPE="fp8"
DEQUANT_FP8_WEIGHTS="all"

SHARDED_CKPT_PATH="/scratch/ramanvr_root/ramanvr/akashpt/DeepSeekRun_runtime/artifacts/deepseek-v3.2-mp2-rerun"

SBATCH_PARTITION="ramanvr"
SBATCH_ACCOUNT="ramanvr"

SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=16
SBATCH_MEM="800G"
SBATCH_TIME="02:00:00"

OMP_NUM_THREADS=16
