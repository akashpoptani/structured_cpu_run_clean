# Baseline clean CPU configuration.
# This file is a design artifact only. No runnable resolver consumes it yet.

# -----------------------------------------------------------------------------
# 1. Experiment
# -----------------------------------------------------------------------------

EXPERIMENT_ID="BASELINE"
RUN_MODE="verify"        # verify | bench | both | generate
RUN_LABEL="BASELINE"

# RUN_MODE values:
# - verify: run correctness check against GPU_REFERENCE_PATH.
# - bench: run timing benchmark only.
# - both: run a small verification case first, then run benchmark.
# - generate: run inference and print generated output without verification or benchmark aggregation.

# -----------------------------------------------------------------------------
# 2. Paths
# -----------------------------------------------------------------------------

PROJECT_ROOT="/home/akashpt/DeepSeekRun/structured_cpu_run_clean"
CLEAN_ROOT="/home/akashpt/DeepSeekRun/structured_cpu_run_clean"
DEEPSEEK_REPO="../DeepSeek-V3.2"
MODEL_PATH_FP8="/scratch/ramanvr_root/ramanvr/akashpt/models/deepseek-v3.2"
MODEL_PATH_BF16="/scratch/ramanvr_root/ramanvr/akashpt/models/deepseek-v3.2-bf16/"
TOKENIZER_PATH=""
GPU_REFERENCE_PATH="verification/references/"
OUTPUT_ROOT="results_clean"

# TOKENIZER_PATH may remain empty for now. Later resolver logic can derive it
# from MODEL_PATH_FP8 or MODEL_PATH_BF16 if needed.
# GPU_REFERENCE_PATH is where the clean lane should expect golden reference
# inputs and outputs for verification.

# -----------------------------------------------------------------------------
# 3. Slurm resources
# -----------------------------------------------------------------------------

SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=96
SBATCH_MEM="950G"
SBATCH_TIME="06:00:00"
SBATCH_PARTITION="standard"

# -----------------------------------------------------------------------------
# 4. Parallelism
# -----------------------------------------------------------------------------

DP_SIZE=2
TP_SIZE=1
EP_SIZE=2
PP_SIZE=1
SHARDING_MODE="dp2_epon"

# PP_SIZE must remain 1 for now (always lol).
# Pipeline parallelism is out of scope.
# SHARDING_MODE is the current high-level mode name used by the existing CPU
# path style.

# -----------------------------------------------------------------------------
# 5. Workload / request
# -----------------------------------------------------------------------------

LIN_TOKENS=10
LOUT_TOKENS=15
BATCH_SIZE=1
INFERENCE_ARCHITECTURE="direct_native"   # direct_native | server_client
STREAMING=0
SESSION_MODE=0

# INFERENCE_ARCHITECTURE describes the execution architecture.
# direct_native means direct PyTorch model.forward path.
# server_client is future-facing and not implemented yet.
# STREAMING means exposing tokens/results incrementally as they are generated,
# instead of only after the full decode finishes.
# STREAMING is not important for direct_native right now and should stay 0.
# BATCH_SIZE is the number of prompts processed together.
# SESSION_MODE means one allocation can run multiple cases without restarting
# everything.

# -----------------------------------------------------------------------------
# 6. Precision
# -----------------------------------------------------------------------------

WEIGHTS_PRECISION="bf16"
KV_CACHE_DTYPE="fp8"

# WEIGHTS_PRECISION and KV_CACHE_DTYPE are separate concepts.
# bf16 KV cache is not implemented end-to-end yet.

# -----------------------------------------------------------------------------
# 7. Runtime flags
# -----------------------------------------------------------------------------

OMP_NUM_THREADS=48
OMP_PROC_BIND="close"
OMP_PLACES="cores"
FAST_LINEAR=0
BATCHED_MOE=0
AMX_ENABLED=0
DEQUANT_FP8_WEIGHTS="none"

# OMP_NUM_THREADS: number of OpenMP threads per rank.
# OMP_PROC_BIND: OpenMP thread binding policy.
# OMP_PLACES: OpenMP placement policy.
# FAST_LINEAR: enable optional fast linear / GEMV path when implemented in clean lane.
# BATCHED_MOE: enable experimental batched MoE path; default off.
# AMX_ENABLED: whether AMX-specific optimized paths are allowed; default off.
# DEQUANT_FP8_WEIGHTS: controls FP8-to-BF16 dequant behavior; default none.

# -----------------------------------------------------------------------------
# 8. Profiling
# -----------------------------------------------------------------------------

MEM_PROFILE=0
TIME_PROFILE=0
PROFILE_GRANULARITY="off"

# MEM_PROFILE enables memory breakdown when implemented.
# TIME_PROFILE enables component timing when implemented.
# PROFILE_GRANULARITY can later be off | coarse | detailed.
