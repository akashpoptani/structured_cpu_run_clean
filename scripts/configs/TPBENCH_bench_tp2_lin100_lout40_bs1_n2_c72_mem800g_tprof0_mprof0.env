# TPBENCH (bench): TP2 dequant=all timing/throughput benchmark with synthetic
# exact-token prompt at Lin=100/Lout=40. Reads the BF16 dequant cache when
# present; writes it on the first run if missing (read_or_write).
# Emits TTFT, TPOT, tokens-per-second.

EXPERIMENT_ID="TPBENCH"
RUN_LABEL="TPBENCH"
RUN_MODE="bench"
REAL_RUN=1

NATIVE_NO_LOAD_WEIGHTS=0
NATIVE_NO_GENERATE=0

SHARDING_MODE="tp2"
TP_SIZE=2
DP_SIZE=1
EP_SIZE=1
PP_SIZE=1

WEIGHTS_PRECISION="fp8"
KV_CACHE_DTYPE="fp8"
DEQUANT_FP8_WEIGHTS="all"
DEQUANT_CACHE_MODE="read_or_write"
DEQUANT_CACHE_PATH="/scratch/ramanvr_root/ramanvr/akashpt/models/deepseek-v3.2-tp2-bf16-dequant-all"

SHARDED_CKPT_PATH="/scratch/ramanvr_root/ramanvr/akashpt/DeepSeekRun_runtime/artifacts/deepseek-v3.2-mp2-rerun"

SBATCH_PARTITION="ramanvr"
SBATCH_ACCOUNT="ramanvr"

SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=72
SBATCH_MEM="800G"
SBATCH_TIME="02:00:00"

OMP_NUM_THREADS=72

LIN_TOKENS=100
LOUT_TOKENS=40
BATCH_SIZE=1
