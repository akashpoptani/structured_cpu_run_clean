# TPGEN: TP2 generate-mode run. Greedy-decodes each reference case and
# writes native_generate_results.json (tokens + decoded text). No compare
# against expected tokens. Same model shape and shards as the known-good
# TPCHECKREAL verify config; the only change is RUN_MODE="generate".
# Resources sized to fit on ramanvr's mixed-state nodes immediately
# (each currently has ~16 free CPUs and ~880 GB free memory).
# Walltime anchored to the known-good c16 dequant=none decode wall (~63 min).

EXPERIMENT_ID="TPGEN_LIN10"
RUN_LABEL="TPGEN_LIN10"
RUN_MODE="generate"
REAL_RUN=1

NATIVE_NO_LOAD_WEIGHTS=0
NATIVE_NO_GENERATE=0

SHARDING_MODE="tp2"
TP_SIZE=2
DP_SIZE=1
EP_SIZE=1
PP_SIZE=1

WEIGHTS_PRECISION="fp8"
KV_CACHE_DTYPE="fp8"
DEQUANT_FP8_WEIGHTS="none"

SHARDED_CKPT_PATH="/scratch/ramanvr_root/ramanvr/akashpt/DeepSeekRun_runtime/artifacts/deepseek-v3.2-mp2-rerun"

SBATCH_PARTITION="ramanvr"
SBATCH_ACCOUNT="ramanvr"

SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=16
SBATCH_MEM="500G"
SBATCH_TIME="02:00:00"

OMP_NUM_THREADS=16
