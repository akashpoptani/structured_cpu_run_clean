# TPGEN (generate): TP2 dequant=all greedy generation with synthetic exact-token
# prompts at Lin=100/Lout=40. Uses the BF16 dequant cache when present;
# writes it on the first run that hits a missing cache (read_or_write).
#
# Resources sized for empty project_l: 96 cores per node, 800 GB per node.
# At dequant=all the F.linear path hits AMX BF16 brgemm, which is
# compute-bound (unlike the FP8 fallback which was memory-bandwidth-bound
# and didn't scale past 16 cores). Walltime accommodates the first-run
# cache write (~5 min) on top of the dequant pass (~51 min observed).

EXPERIMENT_ID="TPGEN"
RUN_LABEL="TPGEN"
RUN_MODE="generate"
REAL_RUN=1

NATIVE_NO_LOAD_WEIGHTS=0
NATIVE_NO_GENERATE=0

SHARDING_MODE="tp2"
TP_SIZE=2
DP_SIZE=1
EP_SIZE=1
PP_SIZE=1

WEIGHTS_PRECISION="fp8"
KV_CACHE_DTYPE="fp8"
DEQUANT_FP8_WEIGHTS="all"
DEQUANT_CACHE_MODE="read_or_write"
DEQUANT_CACHE_PATH="/scratch/ramanvr_root/ramanvr/akashpt/models/deepseek-v3.2-tp2-bf16-dequant-all"

SHARDED_CKPT_PATH="/scratch/ramanvr_root/ramanvr/akashpt/DeepSeekRun_runtime/artifacts/deepseek-v3.2-mp2-rerun"

SBATCH_PARTITION="ramanvr"
SBATCH_ACCOUNT="ramanvr"

SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=16
SBATCH_MEM="800G"
SBATCH_TIME="02:00:00"

OMP_NUM_THREADS=16

LIN_TOKENS=100
LOUT_TOKENS=40
BATCH_SIZE=1
