# TPCHECKREAL override: first real distributed TP2 native verification attempt.
# Parser behavior:
#   source scripts/configs/_baseline.env
#   source this file
#
# This config is the FIRST clean-lane attempt at running a real
# torch.distributed TP2 inference (not a mock/dry-run). It should only be
# submitted inside a 2-node Slurm allocation. submit_experiment.sh with
# REAL_RUN=1 generates an sbatch that calls scripts/run_native_distributed.sh
# instead of the run_case.sh placeholder.

EXPERIMENT_ID="TPCHECKREAL"
RUN_LABEL="TPCHECKREAL"
RUN_MODE="verify"
REAL_RUN=1

SHARDING_MODE="tp2"
TP_SIZE=2
DP_SIZE=1
EP_SIZE=1
PP_SIZE=1

WEIGHTS_PRECISION="fp8"
KV_CACHE_DTYPE="fp8"

# Match legacy TP2 pre-dequant convention (token-exact baseline).
DEQUANT_FP8_WEIGHTS="all"

# Per-rank TP2 safetensor shards under DeepSeekRun_runtime scratch.
# Absolute scratch path; bypasses the legacy artifacts/-active symlink chain.
# Contains: model0-mp2.safetensors, model1-mp2.safetensors, tokenizer.json,
# tokenizer_config.json, config.json, generation_config.json.
SHARDED_CKPT_PATH="/scratch/ramanvr_root/ramanvr/akashpt/DeepSeekRun_runtime/artifacts/deepseek-v3.2-mp2-rerun"

SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=32
SBATCH_MEM="750G"
SBATCH_TIME="02:00:00"

OMP_NUM_THREADS=32

# Staged-testing knobs. Leave both at 0 for the final real run. To run a
# weight-load smoke without generation, flip NATIVE_NO_GENERATE to 1 first
# and re-run submit_experiment.sh TPCHECKREAL. Setting NATIVE_NO_LOAD_WEIGHTS=1
# constructs the model only; it is mainly useful as a safe local check
# (login node), not as a Slurm-submitted stage.
NATIVE_NO_LOAD_WEIGHTS=0
NATIVE_NO_GENERATE=0
