# TPCHECKREAL override: first real distributed TP2 native verification attempt.
# Parser behavior:
#   source scripts/configs/_baseline.env
#   source this file
#
# This config is the FIRST clean-lane attempt at running a real
# torch.distributed TP2 inference (not a mock/dry-run). It should only be
# submitted inside a 2-node Slurm allocation. submit_experiment.sh with
# REAL_RUN=1 generates an sbatch that calls scripts/run_native_distributed.sh
# instead of the run_case.sh placeholder.

EXPERIMENT_ID="TPCHECKREAL"
RUN_LABEL="TPCHECKREAL"
RUN_MODE="verify"
REAL_RUN=1

SHARDING_MODE="tp2"
TP_SIZE=2
DP_SIZE=1
EP_SIZE=1
PP_SIZE=1

WEIGHTS_PRECISION="fp8"
KV_CACHE_DTYPE="fp8"

# Match legacy TP2 pre-dequant convention (token-exact baseline).
DEQUANT_FP8_WEIGHTS="all"

# Per-rank TP2 safetensor shards live in the legacy artifacts directory.
# This is a data path only; no Python from there is imported at runtime.
SHARDED_CKPT_PATH="../structured_cpu_run/artifacts/deepseek-v3.2-mp2-active"

SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=32
SBATCH_MEM="750G"
SBATCH_TIME="02:00:00"

OMP_NUM_THREADS=32
