# TPBOTH: TP2 both-mode run. Verifies first; if all cases pass token-exact,
# re-uses the same decode timings to compute bench metrics. Writes:
#   results_clean/results/TPBOTH/native_verify_results.json
#   results_clean/results/TPBOTH/native_bench_results.json
#   results_clean/results/TPBOTH/native_both_results.json
# Since the implementation reuses one decode pass for both phases, the
# walltime is the same as a single verify or bench run.

EXPERIMENT_ID="TPBOTH"
RUN_LABEL="TPBOTH"
RUN_MODE="both"
REAL_RUN=1

NATIVE_NO_LOAD_WEIGHTS=0
NATIVE_NO_GENERATE=0

SHARDING_MODE="tp2"
TP_SIZE=2
DP_SIZE=1
EP_SIZE=1
PP_SIZE=1

WEIGHTS_PRECISION="fp8"
KV_CACHE_DTYPE="fp8"
DEQUANT_FP8_WEIGHTS="none"

SHARDED_CKPT_PATH="/scratch/ramanvr_root/ramanvr/akashpt/DeepSeekRun_runtime/artifacts/deepseek-v3.2-mp2-rerun"

SBATCH_PARTITION="ramanvr"
SBATCH_ACCOUNT="ramanvr"

SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=16
SBATCH_MEM="500G"
SBATCH_TIME="02:00:00"

OMP_NUM_THREADS=16
