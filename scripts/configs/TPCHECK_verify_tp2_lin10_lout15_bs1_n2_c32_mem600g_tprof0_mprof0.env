# TP_CHECK override.
# Parser behavior:
#   source scripts/configs/_baseline.env
#   source this file
# This file contains experiment identity, key mode declarations, and values
# that differ from baseline.

EXPERIMENT_ID="TPCHECK"
RUN_LABEL="TPCHECK"
RUN_MODE="verify"

SHARDING_MODE="tp2"
TP_SIZE=2
DP_SIZE=1
EP_SIZE=1
PP_SIZE=1

WEIGHTS_PRECISION="fp8"
KV_CACHE_DTYPE="fp8"

SBATCH_CPUS_PER_TASK=32
SBATCH_MEM="600G"
SBATCH_TIME="01:00:00"

OMP_NUM_THREADS=32
