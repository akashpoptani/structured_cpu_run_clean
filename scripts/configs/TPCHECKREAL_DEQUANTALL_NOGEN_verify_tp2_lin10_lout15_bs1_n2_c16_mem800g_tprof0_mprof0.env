# TPCHECKREAL_DEQUANTALL_NOGEN: weight-load + dequant smoke for the fast path.
# Parser flow: source _baseline.env, then this file.
#
# Same as TPCHECKREAL_DEQUANTALL but stops before the decode loop. Exercises:
#   - dist init + Transformer construction (TP2 sharded)
#   - per-rank safetensor load
#   - DEQUANT_FP8_WEIGHTS="all" pass over every FP8 Linear weight
# and exits cleanly. Use this as the first stage of the fast-path bring-up.

EXPERIMENT_ID="TPCHECKREAL_DEQUANTALL_NOGEN"
RUN_LABEL="TPCHECKREAL_DEQUANTALL_NOGEN"
RUN_MODE="verify"
REAL_RUN=1

NATIVE_NO_LOAD_WEIGHTS=0
NATIVE_NO_GENERATE=1

SHARDING_MODE="tp2"
TP_SIZE=2
DP_SIZE=1
EP_SIZE=1
PP_SIZE=1

WEIGHTS_PRECISION="fp8"
KV_CACHE_DTYPE="fp8"
DEQUANT_FP8_WEIGHTS="all"

SHARDED_CKPT_PATH="/scratch/ramanvr_root/ramanvr/akashpt/DeepSeekRun_runtime/artifacts/deepseek-v3.2-mp2-rerun"

SBATCH_PARTITION="ramanvr"
SBATCH_ACCOUNT="ramanvr"

SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=16
SBATCH_MEM="800G"
SBATCH_TIME="02:00:00"

OMP_NUM_THREADS=16
