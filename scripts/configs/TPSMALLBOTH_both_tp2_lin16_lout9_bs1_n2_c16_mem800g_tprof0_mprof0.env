# TPSMALLBOTH: short verify (reference Lin=10/Lout=15) then bench
# (synthetic Lin=16/Lout=9) on the cached BF16 fast path. Two decode
# passes in one job — fast iteration variant of TPBOTH.

EXPERIMENT_ID="TPSMALLBOTH"
RUN_LABEL="TPSMALLBOTH"
RUN_MODE="both"
REAL_RUN=1

NATIVE_NO_LOAD_WEIGHTS=0
NATIVE_NO_GENERATE=0

SHARDING_MODE="tp2"
TP_SIZE=2
DP_SIZE=1
EP_SIZE=1
PP_SIZE=1

WEIGHTS_PRECISION="fp8"
KV_CACHE_DTYPE="fp8"
DEQUANT_FP8_WEIGHTS="all"
DEQUANT_CACHE_MODE="read"
DEQUANT_CACHE_PATH="/scratch/ramanvr_root/ramanvr/akashpt/models/deepseek-v3.2-tp2-bf16-dequant-all"

SHARDED_CKPT_PATH="/scratch/ramanvr_root/ramanvr/akashpt/DeepSeekRun_runtime/artifacts/deepseek-v3.2-mp2-rerun"

SBATCH_PARTITION="ramanvr"
SBATCH_ACCOUNT="ramanvr"

SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=16
SBATCH_MEM="800G"
SBATCH_TIME="01:00:00"

OMP_NUM_THREADS=16

LIN_TOKENS=16
LOUT_TOKENS=9
BATCH_SIZE=1
