# TPCHECKREAL_NOGEN: TP2 weight-load-only smoke (skip generation).
# Parser flow: source _baseline.env, then this file.
#
# Loads the per-rank shard model{rank}-mp2.safetensors and reports
# missing/unexpected keys, then exits 0 without running forward.

EXPERIMENT_ID="TPCHECKREAL_NOGEN"
RUN_LABEL="TPCHECKREAL_NOGEN"
RUN_MODE="verify"
REAL_RUN=1

NATIVE_NO_LOAD_WEIGHTS=0
NATIVE_NO_GENERATE=1

SHARDING_MODE="tp2"
TP_SIZE=2
DP_SIZE=1
EP_SIZE=1
PP_SIZE=1

WEIGHTS_PRECISION="fp8"
KV_CACHE_DTYPE="fp8"
DEQUANT_FP8_WEIGHTS="none"

SHARDED_CKPT_PATH="/scratch/ramanvr_root/ramanvr/akashpt/DeepSeekRun_runtime/artifacts/deepseek-v3.2-mp2-rerun"

SBATCH_PARTITION="project_l"
SBATCH_ACCOUNT="kdur"

SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=16
SBATCH_MEM="400G"
SBATCH_TIME="02:00:00"

OMP_NUM_THREADS=16
