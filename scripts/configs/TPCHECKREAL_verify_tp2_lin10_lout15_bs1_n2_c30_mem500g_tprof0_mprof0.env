# TPCHECKREAL: full real TP2 token-exact verification.
# Parser flow: source _baseline.env, then this file.
#
# Same shape as the known-good run (job 27216172) which produced the clean
# lane's first token-exact PASS against
# verification/references/prompt1_bs1_lin10_lout15/case_0001.json. Resources
# bumped to the next tier of open project_l capacity: 30 cores per rank,
# 500 GB per rank.
#
# DEQUANT_FP8_WEIGHTS="none" leaves FP8 weights in place so each rank fits
# in ~500 GB. The per-call FP32 fallback in src/overrides/kernel.py:fp8_gemm
# runs instead of the BF16 fast path. Correct, but ~10x slower than the
# legacy dequant=all + AMX BF16 brgemm path.

EXPERIMENT_ID="TPCHECKREAL"
RUN_LABEL="TPCHECKREAL"
RUN_MODE="verify"
REAL_RUN=1

NATIVE_NO_LOAD_WEIGHTS=0
NATIVE_NO_GENERATE=0

SHARDING_MODE="tp2"
TP_SIZE=2
DP_SIZE=1
EP_SIZE=1
PP_SIZE=1

WEIGHTS_PRECISION="fp8"
KV_CACHE_DTYPE="fp8"
DEQUANT_FP8_WEIGHTS="none"

SHARDED_CKPT_PATH="/scratch/ramanvr_root/ramanvr/akashpt/DeepSeekRun_runtime/artifacts/deepseek-v3.2-mp2-rerun"

SBATCH_PARTITION="project_l"
SBATCH_ACCOUNT="kdur"

SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=30
SBATCH_MEM="500G"
SBATCH_TIME="02:00:00"

OMP_NUM_THREADS=30
