# TPDEQUANTCACHE_PRIME: one-shot cache writer. Loads FP8 shards, runs the
# scope=all dequant pass, writes the per-rank BF16 cache to scratch, then
# exits before the decode loop (NATIVE_NO_GENERATE=1). Run this once before
# the first parallel use of TPGEN/TPBENCH/TPBOTH to avoid a write race
# between concurrent jobs that all hit a missing cache.

EXPERIMENT_ID="TPDEQUANTCACHE_PRIME"
RUN_LABEL="TPDEQUANTCACHE_PRIME"
RUN_MODE="verify"
REAL_RUN=1

NATIVE_NO_LOAD_WEIGHTS=0
NATIVE_NO_GENERATE=1

SHARDING_MODE="tp2"
TP_SIZE=2
DP_SIZE=1
EP_SIZE=1
PP_SIZE=1

WEIGHTS_PRECISION="fp8"
KV_CACHE_DTYPE="fp8"
DEQUANT_FP8_WEIGHTS="all"
DEQUANT_CACHE_MODE="write"
DEQUANT_CACHE_PATH="/scratch/ramanvr_root/ramanvr/akashpt/models/deepseek-v3.2-tp2-bf16-dequant-all"

SHARDED_CKPT_PATH="/scratch/ramanvr_root/ramanvr/akashpt/DeepSeekRun_runtime/artifacts/deepseek-v3.2-mp2-rerun"

SBATCH_PARTITION="ramanvr"
SBATCH_ACCOUNT="ramanvr"

SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=16
SBATCH_MEM="800G"
SBATCH_TIME="02:00:00"

OMP_NUM_THREADS=16

# Reference-case footprint is fine here; the decode loop is skipped.
LIN_TOKENS=10
LOUT_TOKENS=15
BATCH_SIZE=1
