# TPSESSION: TP2 dequant=all session running TPGEN -> TPBENCH -> TPBOTH
# sequentially in one Slurm allocation. Model construction, weight load,
# and (optional) dequant happen ONCE; each child mode just runs its decode
# pass and writes its own result JSON.
#
# Validation invariants enforced by submit_session.sh:
#   all children share SHARDING_MODE, TP/DP/EP/PP, WEIGHTS_PRECISION,
#   SHARDED_CKPT_PATH, MODEL_ARGS_CONFIG_PATH, DEQUANT_FP8_WEIGHTS.
# Cache config below is the single source of truth for the session and
# overrides each child's DEQUANT_CACHE_MODE / DEQUANT_CACHE_PATH.

SESSION_TAG="TPSESSION"
SESSION_CHILDREN="TPGEN TPBENCH TPBOTH"

# sbatch resource ask shared by the whole session.
SBATCH_PARTITION="ramanvr"
SBATCH_ACCOUNT="ramanvr"
SBATCH_NODES=2
SBATCH_TASKS_PER_NODE=1
SBATCH_CPUS_PER_TASK=16
SBATCH_MEM="800G"
SBATCH_TIME="03:00:00"

OMP_NUM_THREADS=16
OMP_PROC_BIND="close"
OMP_PLACES="cores"

# Cache: turned OFF for this session because writing the ~338 GB BF16 cache
# per rank pushes Linux page cache + RSS past the cgroup --mem=800G limit
# and triggers OOM-killer (observed in PRIME job 27226638). A sharded
# write path is the documented next step; until then the session pays one
# dequant pass and reuses the in-memory model across all child phases.
DEQUANT_CACHE_MODE="off"
DEQUANT_CACHE_PATH=""
